# Root .gitignore for Innovatech Chile repository

# System files
.DS_Store
Thumbs.db
ehthumbs.db

# IDE / editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml
*.iws
*.classpath
*.project

# Node dependencies and build artifacts
node_modules/
/dist/
/build/
/.vite/
/npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Java build artifacts
target/
*.jar
*.war
*.ear
*.class
*.log

# Spring Boot and Maven
.mvn/
!/.mvn/wrapper/maven-wrapper.jar

# Environment / secret files
.env
.env.*
*.local
*.secret
*.key
*.pem
*.crt
*.p12
*.jks
credentials
aws-credentials

# Docker
docker-compose.override.yml
.docker/

# Database local files
*.sql
*.sqlite
*.db

# Misc
*.tmp
*.temp
*.bak
*.orig

# GitHub Actions artifacts
.github/actions/**/node_modules/

# Ignore OS-specific files
desktop.ini

# Logs
npm-debug.log*
log/
logs/
